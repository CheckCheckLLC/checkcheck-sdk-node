{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext", // Changed to support ESM
    "moduleResolution": "node",
    "declaration": true, // Still useful for IDE
    "outDir": "./dist", // Match tsup output
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true // Speed up IDE checks
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
