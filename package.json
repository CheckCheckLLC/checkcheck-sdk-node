{
  "name": "@CheckCheckLLC/checkcheck",
  "version": "0.0.1",
  "description": "CheckCheck Node SDK for sneaker authentication services",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CheckCheckLLC/checkcheck.git"
  },
  "bugs": {
    "url": "https://github.com/CheckCheckLLC/checkcheck/issues"
  },
  "homepage": "https://github.com/CheckCheckLLC/checkcheck#readme",
  "keywords": [
    "api",
    "sdk",
    "checkcheck"
  ],
  "author": "CheckCheck",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@faker-js/faker": "^9.7.0",
    "axios": "^1.7.9",
    "form-data": "^4.0.2",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "prettier-plugin-organize-imports": "^4.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  }
}
